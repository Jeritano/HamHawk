{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HamHawk",
  "version": "0.1.0",
  "identifier": "com.hamhawk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "HamHawk",
        "width": 1200,
        "height": 780,
        "minWidth": 940,
        "minHeight": 620,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
